rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // GLOBAL SAFETY NET - DEFAULT DENY
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // PRIMITIVE HELPERS
    // ===============================================================
    function isAuthenticated() { return request.auth != null; }
    function isEmailVerified() { return isAuthenticated() && request.auth.token.email_verified == true; }
    function getEmail() { return request.auth.token.email; }
    function getUid() { return request.auth.uid; }
    
    // Hardcoded Admin identity for bootstrapping and fail-safe access
    function isHardcodedAdmin() {
      return isAuthenticated() && (
        getEmail() == "webpmp@gmail.com" ||
        getUid() == "A32rRWuWIeTvzO5SDqJxk2j4ePF3"
      );
    }

    function isAdmin() {
      return isHardcodedAdmin() || (
        isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(getUid())) && 
        get(/databases/$(database)/documents/users/$(getUid())).data.role == "Admin"
      );
    }

    function isPrivileged() {
      return isHardcodedAdmin() || isAdmin();
    }

    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(getUid()))
        ? get(/databases/$(database)/documents/users/$(getUid())).data.role
        : "Guest";
    }

    function isFacilitator() {
      return isAdmin() || getUserRole() == "Facilitator";
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ===============================================================
    // VALIDATION BLUEPRINTS
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'role']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.size() < 100 &&
             data.role in ["Admin", "Facilitator", "Reviewer", "Requestor", "Participant", "Watcher", "Guest"] &&
             (!('availability' in data) || data.availability is list);
    }

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'status', 'requestorId', 'disclosureRequired', 'createdAt']) &&
             data.title is string && data.title.size() > 1 && data.title.size() < 200 &&
             data.status in ["Intake", "Discovery", "Design", "Follow-up", "Fit & Finish", "Approved", "Approved-Changes Required"] &&
             (isAdmin() || data.requestorId == getUid()) &&
             data.disclosureRequired is bool &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             (!('timeline' in data) || (data.timeline is string && data.timeline.size() <= 500)) &&
             (!('priorWorkLink' in data) || (data.priorWorkLink is string && data.priorWorkLink.size() <= 1000));
    }

    function isValidReview(data) {
      return data.keys().hasAll(['projectId', 'stageType', 'status']) &&
             isValidId(data.projectId) &&
             data.stageType in ["Discovery", "Design", "Follow-up", "Fit & Finish"] &&
             data.status in ["Pending", "Scheduled", "Completed", "Approved", "Approved with Revisions", "Not Approved"] &&
             (data.status != "Scheduled" || ('scheduledTime' in data && data.scheduledTime is string));
    }

    function isValidFeedback(data) {
      return data.keys().hasAll(['reviewId', 'projectId', 'authorId', 'status', 'createdAt']) &&
             isValidId(data.reviewId) &&
             isValidId(data.projectId) &&
             data.authorId == getUid() &&
             data.status in ["Open", "Addressed", "Ignored", "Approved", "Approved with Revisions", "Not Approved"] &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 10000));
    }

    function isValidMember(data) {
      return data.keys().hasAll(['projectId', 'userId', 'email', 'role']) &&
             isValidId(data.projectId) &&
             isValidId(data.userId) &&
             data.email is string &&
             data.role is string;
    }

    // ===============================================================
    // COLLECTION RULES
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && isValidUser(incoming()) && 
                    ((getUid() == userId && (incoming().role == "Guest" || incoming().role == "Requestor")) || isPrivileged());
                    
      allow update: if isAuthenticated() && isValidUser(incoming()) &&
                    ((getUid() == userId && incoming().role == existing().role) || isPrivileged());

      allow delete: if isAuthenticated() && isPrivileged();
    }

    match /projects/{projectId} {
      allow get: if isAuthenticated() && (
        isHardcodedAdmin() || 
        isAdmin() || 
        resource == null ||
        resource.data.disclosureRequired == false ||
        resource.data.requestorId == getUid() ||
        // Relationship lookup
        exists(/databases/$(database)/documents/project_members/$(getUid() + "_" + projectId))
      );
      
      allow list: if isAuthenticated() && (
        isHardcodedAdmin() || 
        isAdmin() || 
        (resource != null && resource.data.disclosureRequired == false) ||
        (resource != null && resource.data.requestorId == getUid())
      );
      
      allow create: if isAuthenticated() && (isEmailVerified() || isPrivileged()) && isValidProject(incoming()) && (isPrivileged() || getUserRole() in ["Requestor", "Facilitator"]);
                    
      allow update: if isAuthenticated() && isValidProject(incoming()) && (
                      isAdmin() || 
                      getUserRole() == "Facilitator" ||
                      (existing().requestorId == getUid() && incoming().requestorId == existing().requestorId)
                    );

      allow delete: if isAuthenticated() && isPrivileged();
    }

    match /project_members/{memberId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (isAdmin() || getUserRole() == "Facilitator") && isValidMember(incoming());
      allow delete: if isAuthenticated() && (isAdmin() || getUserRole() == "Facilitator");
    }
    
    match /reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidReview(incoming()) && (isFacilitator() || getUserRole() in ["Requestor", "Reviewer"]);
      allow delete: if isAdmin();
    }
    
    match /feedback/{feedbackId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidFeedback(incoming());
      allow update: if isAuthenticated() && isValidFeedback(incoming()) && (isAdmin() || existing().authorId == getUid() || getUserRole() == "Facilitator");
      allow delete: if isAdmin() || existing().authorId == getUid();
    }

    match /project_history/{historyId} {
      allow read: if isAuthenticated() && isPrivileged();
      allow create: if isAuthenticated(); // Application code handles access control for history writes
      allow update, delete: if false; // History is immutable
    }

    match /holidays/{holidayId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && isPrivileged();
    }

    match /system_settings/{settingId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && isPrivileged();
    }
  }
}
